rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "5ej852963@gmail.com" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    // Settings (Global Config, Ticker, etc.)
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // News
    match /news/{newsId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Comments
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.uid || isAdmin());
    }

    // Users
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // Subscribers
    match /subscribers/{email} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Billboard / Ads
    match /billboard/{adId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Chats (Logging)
    match /chats/{chatId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Institutional Logic
    match /institutional_logic/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Mail (Trigger Email Extension)
    match /mail/{mailId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }
    
    // Broadcasts
    match /broadcasts/{id} {
      allow read, write: if isAdmin();
    }

    // Feedback
    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }
  }
}
